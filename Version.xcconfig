// Single source of truth for the app + widget version.
// Wired as the project-level base configuration, so both targets inherit these.
// Bump these for each release instead of editing per-target build settings.

// Marketing version (CFBundleShortVersionString), e.g. 1.0, 1.1, 2.0
MARKETING_VERSION = 1.0

// Build number (CFBundleVersion) — increment for every App Store / TestFlight upload
CURRENT_PROJECT_VERSION = 1
